<% return unless current_user_admin? %>

<div class="form-section mt-3" id="trainer-capabilities-panel">
  <div class="form-section-header">
    <span class="h-section-label">Trainer capabilities</span>
    <span class="text-12 text-secondary">Admin only</span>
  </div>
  <div class="text-13 text-secondary mb-3">
    Grant or revoke who can train others in each topic.
  </div>

  <div class="mb-3" data-controller="live-filter" data-live-filter-min-length-value="2">
    <label class="text-12 text-secondary mb-1">Member</label>
    <input type="text"
           class="form-control form-control-sm"
           placeholder="Search by name, email, or username..."
           autocomplete="off"
           autocorrect="off"
           autocapitalize="off"
           spellcheck="false"
           data-live-filter-target="input"
           data-action="input->live-filter#filter keyup->live-filter#filter">
    <div class="mt-2 d-none border rounded"
         style="max-height: 280px; overflow-y: auto;"
         data-live-filter-target="resultsContainer">
      <% @users_for_search.each do |user| %>
        <%= link_to record_training_path(
              trainer_user_id: user.id,
              topic_id: params[:topic_id],
              trainee_ids: params[:trainee_ids]
            ),
            class: "search-result-item d-none d-block p-2 text-decoration-none border-bottom text-13 #{
              @trainer_manage_user&.id == user.id ? 'bg-primary-subtle border-primary' : ''
            }",
            data: {
              live_filter_target: 'item',
              search_text: [user.display_name, user.email, user.username].compact.join(' ').downcase
            } do %>
          <div class="fw-medium"><%= user.display_name %></div>
          <% if user.email.present? %>
            <div class="text-11 text-secondary"><%= user.email %></div>
          <% end %>
        <% end %>
      <% end %>
    </div>
    <div class="mt-2 p-3 text-center text-secondary border rounded text-13 d-none"
         data-live-filter-target="noResults">
      No members found matching your search.
    </div>
  </div>

  <% if @trainer_manage_user %>
    <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
      <div class="text-13">
        <span class="text-secondary">Managing:</span>
        <span class="fw-medium"><%= @trainer_manage_user.display_name %></span>
      </div>
      <%= link_to "View profile", user_path(@trainer_manage_user), class: "btn btn-outline-secondary btn-sm" %>
    </div>

    <% trainer_topic_ids = @trainer_manage_user.training_topics.pluck(:id) %>
    <div class="d-flex flex-wrap gap-1">
      <% @all_training_topics.each do |topic| %>
        <% is_trainer = trainer_topic_ids.include?(topic.id) %>
        <div class="d-inline-flex align-items-center border rounded px-2 py-1 text-12 <%= is_trainer ? 'border-success' : 'text-secondary' %>">
          <%= link_to topic.name, edit_training_topic_path(topic), class: "me-1 text-decoration-none #{'fw-medium' if is_trainer}" %>
          <% if is_trainer %>
            <%= button_to remove_trainer_capability_path(user_id: @trainer_manage_user.id, topic_id: topic.id),
                method: :delete,
                class: "btn btn-sm btn-outline-danger py-0 px-1 ms-1",
                title: "Revoke trainer capability",
                form: { class: 'd-inline trainer-capability-form' },
                params: {
                  return_topic_id: params[:topic_id],
                  return_trainee_ids: params[:trainee_ids]
                },
                data: { turbo_confirm: "Remove #{topic.name} trainer capability from #{@trainer_manage_user.display_name}?" } do %>
              <i class="bi bi-x-lg"></i>
            <% end %>
          <% else %>
            <%= button_to add_trainer_capability_path(user_id: @trainer_manage_user.id, topic_id: topic.id),
                method: :post,
                class: "btn btn-sm btn-outline-secondary py-0 px-1 ms-1",
                title: "Grant trainer capability",
                form: { class: 'd-inline trainer-capability-form' },
                params: {
                  return_topic_id: params[:topic_id],
                  return_trainee_ids: params[:trainee_ids]
                } do %>
              <i class="bi bi-plus-lg"></i>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-13 text-secondary mb-0">Search for a member above to manage their trainer capabilities.</p>
  <% end %>
</div>
