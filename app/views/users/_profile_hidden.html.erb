<div class="text-center py-5">
  <i class="bi bi-lock text-secondary" style="font-size: 2rem;" aria-hidden="true"></i>
  <h1 class="h4 mt-3 mb-1"><%= user.display_name %></h1>
  <p class="text-secondary mb-0">
    <% if view_level == :public %>
