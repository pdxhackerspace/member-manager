<div class="row justify-content-center py-5">
  <div class="col-12 col-md-10 col-lg-8">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body p-4 p-md-5">
        <h2 class="h4 mb-3">Membership Application</h2>
        <p>
          Thank you for your interest in joining! Before you begin your application, please
          confirm the following and provide your email address.
        </p>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <%= form_with url: apply_new_path, method: :post, local: true do |f| %>

          <div class="mb-4">
            <div class="form-check">
              <input type="checkbox" name="confirmed_open_house" value="1"
                     class="form-check-input" id="confirmed_open_house" required>
              <label class="form-check-label" for="confirmed_open_house">
                <strong>I have attended an open house at the space.</strong>
              </label>
            </div>
          </div>

          <div class="mb-4">
            <div class="form-check">
              <input type="checkbox" name="confirmed_code_of_conduct" value="1"
                     class="form-check-input" id="confirmed_code_of_conduct" required>
              <label class="form-check-label" for="confirmed_code_of_conduct">
                <strong>I have read and agree with the
                <% if @code_of_conduct_url != '#' %>
                  <%= link_to 'Code of Conduct', @code_of_conduct_url, target: '_blank', rel: 'noopener' %>.
                <% else %>
                  Code of Conduct.
                <% end %>
                </strong>
              </label>
            </div>
          </div>

          <hr class="my-4">

          <div class="mb-4">
            <label for="email" class="form-label">
              <strong>Email Address</strong> <span class="text-danger">*</span>
            </label>
            <input type="email" name="email" id="email" class="form-control form-control-lg"
                   placeholder="your.email@example.com" required
                   autocomplete="email">
            <div class="form-text">
              We'll send a verification link to this address. This email will also be used
              for your application and membership.
            </div>
          </div>

          <div class="d-flex justify-content-between">
            <%= link_to "← Back", login_path, class: "btn btn-outline-secondary" %>
            <button type="submit" class="btn btn-primary btn-lg">Send Verification Email →</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
