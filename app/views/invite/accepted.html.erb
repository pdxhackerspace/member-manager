<div class="row justify-content-center mt-5">
  <div class="col-lg-6 col-md-8">

    <% if @error %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-question-circle display-3 text-muted d-block mb-3"></i>
          <h2 class="h4 mb-2">Something went wrong</h2>
          <p class="text-muted">We couldn't find this invitation. Please contact an administrator for help.</p>
        </div>
      </div>
      <% return %>
    <% end %>

    <div class="card shadow-sm border-0">
      <div class="card-body text-center py-5">
        <i class="bi bi-check-circle display-3 text-success d-block mb-3"></i>
        <h2 class="h4 mb-2">Welcome to <%= ENV.fetch('ORGANIZATION_NAME', 'Member Manager') %>!</h2>
        <p class="text-muted mb-4">
          Your account has been created successfully. You're now a <strong><%= @invitation.type_label %></strong>.
        </p>

        <div class="card bg-body-tertiary border-0 mb-4 mx-auto" style="max-width: 350px;">
          <div class="card-body">
            <dl class="row mb-0 text-start">
              <dt class="col-sm-4 text-secondary">Name</dt>
              <dd class="col-sm-8"><%= @user.display_name %></dd>
              <dt class="col-sm-4 text-secondary">Email</dt>
              <dd class="col-sm-8"><%= @user.email %></dd>
              <% if @user.username.present? %>
                <dt class="col-sm-4 text-secondary">Username</dt>
                <dd class="col-sm-8 mb-0"><%= @user.username %></dd>
              <% end %>
            </dl>
          </div>
        </div>

        <p class="text-muted small mb-3">You can now log in to set up your profile and get started.</p>
        <%= link_to "Log In", login_path, class: "btn btn-primary btn-lg" %>
      </div>
    </div>
  </div>
</div>
