<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="h3 mb-1">Mail Log Entry</h1>
    <p class="text-muted mb-0">
      <%= @log_entry.event.humanize %>
      <% if @log_entry.created_at %>
        · <%= @log_entry.created_at.strftime('%b %d, %Y %l:%M %p') %>
      <% end %>
    </p>
  </div>
  <div class="d-flex gap-2">
    <% if @log_entry.queued_mail %>
      <%= link_to "Queued Message", queued_mail_path(@log_entry.queued_mail), class: "btn btn-outline-secondary" %>
    <% end %>
    <%= link_to "Back to Mail Log", mail_log_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="row">
  <div class="col-lg-4 mb-4">
    <div class="card shadow-sm border-0">
      <div class="card-header">
        <h5 class="mb-0">Details</h5>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4 text-secondary">Event</dt>
          <dd class="col-sm-8"><%= @log_entry.event.humanize %></dd>

          <dt class="col-sm-4 text-secondary">To</dt>
          <dd class="col-sm-8"><code><%= @log_entry.message_to %></code></dd>

          <dt class="col-sm-4 text-secondary">Subject</dt>
          <dd class="col-sm-8"><%= @log_entry.message_subject %></dd>

          <% if @log_entry.delivery_mailer.present? %>
            <dt class="col-sm-4 text-secondary">Mailer</dt>
            <dd class="col-sm-8"><code><%= @log_entry.delivery_mailer %>#<%= @log_entry.delivery_action %></code></dd>
          <% end %>

          <% if @log_entry.actor %>
            <dt class="col-sm-4 text-secondary">By</dt>
            <dd class="col-sm-8"><%= link_to @log_entry.actor.display_name, user_path(@log_entry.actor) %></dd>
          <% end %>

          <% if @log_entry.details.present? %>
            <dt class="col-sm-4 text-secondary">Details</dt>
            <dd class="col-sm-8"><%= @log_entry.details %></dd>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-8 mb-4">
    <% if @log_entry.message_body_html.present? %>
      <div class="card shadow-sm border-0">
        <div class="card-header">
          <h5 class="mb-0">Message Sent</h5>
        </div>
        <div class="card-body p-0">
          <iframe id="mail_preview" srcdoc="<%= ERB::Util.html_escape(@log_entry.message_body_html) %>"
                  style="width: 100%; min-height: 400px; border: none;"
                  sandbox="allow-same-origin"></iframe>
        </div>
      </div>
    <% else %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <i class="bi bi-envelope-x display-4 mb-3 d-block text-muted opacity-25"></i>
          <p class="text-muted mb-0">No HTML message snapshot is available for this log entry.</p>
        </div>
      </div>
    <% end %>

    <% if @log_entry.message_body_text.present? %>
      <div class="card shadow-sm border-0 mt-3">
        <div class="card-header">
          <h5 class="mb-0">Plain Text Version</h5>
        </div>
        <div class="card-body">
          <pre class="mb-0 text-body bg-body" style="white-space: pre-wrap;"><%= @log_entry.message_body_text %></pre>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function() {
    function resizeIframe() {
      var iframe = document.getElementById('mail_preview');
      if (!iframe) return;
      iframe.addEventListener('load', function() {
        try {
          var height = iframe.contentDocument.documentElement.scrollHeight;
          iframe.style.height = Math.max(height + 20, 400) + 'px';
        } catch(e) {}
      });
    }
    document.addEventListener('DOMContentLoaded', resizeIframe);
    document.addEventListener('turbo:load', resizeIframe);
  })();
</script>
