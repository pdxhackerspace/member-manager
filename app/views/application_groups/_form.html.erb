<%= form_with model: [@application, @application_group], local: true do |f| %>
  <% if @application_group.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @application_group.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true, id: "application_group_name" %>
  </div>

  <div class="mb-3">
    <%= f.label :authentik_name, "Authentik Group Name", class: "form-label" %>
    <%= f.text_field :authentik_name, class: "form-control", required: true, id: "application_group_authentik_name" %>
    <div class="form-text">The name of this group in Authentik. Auto-generated from the Name field above.</div>
  </div>

  <h5 class="mt-4 mb-3">Group Members</h5>

  <div class="mb-3">
    <div class="form-check mb-2">
      <input type="radio" name="application_group[member_source]" value="sync_group"
             id="member_source_sync_group" class="form-check-input member-source-radio"
             <%= 'checked' if %w[sync_group active_members admin_members unbanned_members all_members].include?(@application_group.member_source) %>>
      <label for="member_source_sync_group" class="form-check-label">Sync with group</label>
      <div id="sync_group_select_wrapper" class="ms-4 mt-1 mb-1" style="display: <%= %w[sync_group active_members admin_members unbanned_members all_members].include?(@application_group.member_source) ? 'block' : 'none' %>;">
        <select name="application_group[sync_group_combined]" id="sync_group_combined" class="form-select form-select-sm" style="max-width: 400px;">
          <option value="">Select a group...</option>
          <option value="active_members" <%= 'selected' if @application_group.member_source == 'active_members' %>>Active Members</option>
          <option value="admin_members" <%= 'selected' if @application_group.member_source == 'admin_members' %>>Admin Members</option>
          <option value="unbanned_members" <%= 'selected' if @application_group.member_source == 'unbanned_members' %>>Unbanned Members</option>
          <option value="all_members" <%= 'selected' if @application_group.member_source == 'all_members' %>>All Members</option>
          <option disabled>──────────</option>
          <% @syncable_groups.each do |group| %>
            <option value="sync_group:<%= group.id %>"
                    <%= 'selected' if @application_group.member_source == 'sync_group' && @application_group.sync_with_group_id == group.id %>>
              <%= group.name %> (<%= group.application.name %>)
            </option>
          <% end %>
        </select>
      </div>
    </div>

    <div class="form-check mb-2">
      <input type="radio" name="application_group[member_source]" value="can_train"
             id="member_source_can_train" class="form-check-input member-source-radio"
             <%= 'checked' if @application_group.member_source == 'can_train' %>>
      <label for="member_source_can_train" class="form-check-label">Members who can train</label>
    </div>

    <div class="form-check mb-2">
      <input type="radio" name="application_group[member_source]" value="trained_in"
             id="member_source_trained_in" class="form-check-input member-source-radio"
             <%= 'checked' if @application_group.member_source == 'trained_in' %>>
      <label for="member_source_trained_in" class="form-check-label">Members trained in</label>
    </div>

    <div id="training_topic_wrapper" class="ms-4 mb-2" style="display: <%= %w[can_train trained_in].include?(@application_group.member_source) ? 'block' : 'none' %>;">
      <%= f.collection_select :training_topic_id, @training_topics, :id, :name,
          { selected: @application_group.training_topic_id, prompt: "Select training topic..." },
          { class: "form-select form-select-sm", id: "application_group_training_topic_id", style: "max-width: 400px;" } %>
    </div>

    <div class="form-check mb-2">
      <input type="radio" name="application_group[member_source]" value="manual"
             id="member_source_manual" class="form-check-input member-source-radio"
             <%= 'checked' if @application_group.member_source == 'manual' %>>
      <label for="member_source_manual" class="form-check-label">Choose members</label>
    </div>
  </div>

  <div id="policy_warning" class="alert alert-info mb-3" style="display: none;">
    <i class="bi bi-info-circle me-2"></i>
    <span id="policy_warning_own">
      This group will create an Authentik expression policy. Bind this policy to your Authentik application to control access:<br>
      <code id="policy_name_display" class="fs-6"></code>
    </span>
    <span id="policy_warning_synced" style="display: none;">
      This group syncs with another group and will use that group's expression policy. Bind the synced group's policy to your Authentik application to control access:<br>
      <code id="synced_policy_name_display" class="fs-6"></code>
    </span>
  </div>

  <%# Hidden fields updated by JS to carry the resolved member_source and sync_with_group_id %>
  <input type="hidden" name="application_group[sync_with_group_id]" id="resolved_sync_with_group_id"
         value="<%= @application_group.sync_with_group_id %>">

  <div class="mb-3">
    <%= f.label :authentik_group_id, "Authentik Group ID", class: "form-label" %>
    <%= f.text_field :authentik_group_id, class: "form-control font-monospace", placeholder: "e.g., 3c894c72-0757-45aa-ac6d-f1bf220a57ec" %>
    <div class="form-text">Optional. The UUID of this group in Authentik. If set, webhook events for this group will be synced.</div>
  </div>

  <div class="mb-3">
    <%= f.label :note, class: "form-label" %>
    <%= f.text_area :note, class: "form-control", rows: 3 %>
    <div class="form-text">Optional note about this group.</div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit @application_group.persisted? ? "Update Group" : "Create Group", class: "btn btn-primary" %>
    <% if @application_group.persisted? %>
      <%= link_to "Cancel", application_application_group_path(@application, @application_group), class: "btn btn-outline-secondary" %>
    <% else %>
      <%= link_to "Cancel", application_path(@application), class: "btn btn-outline-secondary" %>
    <% end %>
  </div>
<% end %>

<script>
(function() {
  const POLICY_PREFIX = '<%= ApplicationGroup::POLICY_NAME_PREFIX %>';

  const radios = document.querySelectorAll('.member-source-radio');
  const syncGroupWrapper = document.getElementById('sync_group_select_wrapper');
  const syncGroupCombined = document.getElementById('sync_group_combined');
  const trainingTopicWrapper = document.getElementById('training_topic_wrapper');
  const nameField = document.getElementById('application_group_name');
  const authentikNameField = document.getElementById('application_group_authentik_name');
  const resolvedSyncGroupId = document.getElementById('resolved_sync_with_group_id');
  const policyWarning = document.getElementById('policy_warning');
  const policyWarningOwn = document.getElementById('policy_warning_own');
  const policyWarningSynced = document.getElementById('policy_warning_synced');
  const policyNameDisplay = document.getElementById('policy_name_display');
  const syncedPolicyNameDisplay = document.getElementById('synced_policy_name_display');

  if (!radios.length || !authentikNameField || !nameField) return;

  const initialValue = authentikNameField.value || '';
  const lastColon = initialValue.lastIndexOf(':');
  const prefix = lastColon >= 0 ? initialValue.substring(0, lastColon + 1) : initialValue;

  const syncGroupPolicyNames = {};
  <% @syncable_groups.each do |group| %>
    syncGroupPolicyNames['<%= group.id %>'] = '<%= j(group.policy_name) %>';
  <% end %>

  const builtinGroupPolicyNames = {
    active_members: POLICY_PREFIX + ':<%= j(@default_settings.active_members_group) %>',
    admin_members: POLICY_PREFIX + ':<%= j(@default_settings.admins_group) %>',
    unbanned_members: POLICY_PREFIX + ':<%= j(@default_settings.unbanned_members_group) %>',
    all_members: POLICY_PREFIX + ':<%= j(@default_settings.all_members_group) %>'
  };

  function slugify(text) {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  }

  function getSelectedSource() {
    for (const r of radios) {
      if (r.checked) return r.value;
    }
    return 'manual';
  }

  function updateAuthentikName() {
    var slug = slugify(nameField.value);
    authentikNameField.value = slug ? prefix + slug : prefix;
    updatePolicyWarning();
  }

  function updatePolicyWarning() {
    const source = getSelectedSource();
    const isNonManual = source !== 'manual';

    if (!isNonManual) {
      policyWarning.style.display = 'none';
      return;
    }

    policyWarning.style.display = 'block';

    var syncedPolicyName = null;

    if (source === 'sync_group') {
      const combined = syncGroupCombined.value;
      if (combined in builtinGroupPolicyNames) {
        syncedPolicyName = builtinGroupPolicyNames[combined];
      } else if (combined.startsWith('sync_group:')) {
        const groupId = combined.split(':')[1];
        if (syncGroupPolicyNames[groupId]) {
          syncedPolicyName = syncGroupPolicyNames[groupId];
        }
      }
    }

    if (syncedPolicyName) {
      policyWarningOwn.style.display = 'none';
      policyWarningSynced.style.display = '';
      syncedPolicyNameDisplay.textContent = syncedPolicyName;
    } else {
      policyWarningOwn.style.display = '';
      policyWarningSynced.style.display = 'none';
      policyNameDisplay.textContent = POLICY_PREFIX + ':' + authentikNameField.value;
    }
  }

  function updateVisibility() {
    const source = getSelectedSource();
    syncGroupWrapper.style.display = (source === 'sync_group') ? 'block' : 'none';
    trainingTopicWrapper.style.display = (source === 'can_train' || source === 'trained_in') ? 'block' : 'none';

    resolvedSyncGroupId.value = '';
    if (source === 'sync_group') {
      const combined = syncGroupCombined.value;
      if (combined.startsWith('sync_group:')) {
        resolvedSyncGroupId.value = combined.split(':')[1];
      }
    }

    updatePolicyWarning();
  }

  nameField.addEventListener('input', updateAuthentikName);
  authentikNameField.addEventListener('input', updatePolicyWarning);
  radios.forEach(function(r) { r.addEventListener('change', updateVisibility); });
  if (syncGroupCombined) syncGroupCombined.addEventListener('change', updateVisibility);

  // Handle form submission: resolve combined select into proper member_source
  const form = document.querySelector('form');
  if (form) {
    form.addEventListener('submit', function() {
      const source = getSelectedSource();
      if (source === 'sync_group') {
        const combined = syncGroupCombined.value;
        if (['active_members', 'admin_members', 'unbanned_members', 'all_members'].includes(combined)) {
          const hiddenSource = document.createElement('input');
          hiddenSource.type = 'hidden';
          hiddenSource.name = 'application_group[member_source]';
          hiddenSource.value = combined;
          form.appendChild(hiddenSource);
          resolvedSyncGroupId.value = '';
        }
      }
    });
  }

  // Initialize on page load
  updateVisibility();
})();
</script>
