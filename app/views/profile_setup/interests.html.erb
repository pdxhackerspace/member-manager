<div class="py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="d-flex justify-content-center mb-4">
        <div class="d-flex align-items-center gap-2">
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">Basic Info</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">About You</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-success"><i class="bi bi-check"></i></span>
          <span class="text-muted small">Links</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-primary">4</span>
          <span class="fw-semibold small">Interests</span>
          <i class="bi bi-chevron-right text-muted mx-1"></i>
          <span class="badge rounded-pill text-bg-secondary">5</span>
          <span class="text-muted small">Visibility</span>
        </div>
      </div>

      <!-- Member summary -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body py-2">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <div>
              <span class="fw-semibold"><%= @user.display_name %></span>
              <span class="text-muted ms-2"><%= @user.email %></span>
              <% if @user.username.present? %>
                <span class="text-muted ms-2">@<%= @user.username %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Interests -->
      <div class="card shadow-sm border-0">
        <div class="card-header bg-body-tertiary">
          <h4 class="card-title mb-0"><i class="bi bi-tags me-2"></i>Interests</h4>
        </div>
        <div class="card-body">
          <div class="alert alert-light border mb-4">
            <i class="bi bi-info-circle me-1"></i>
            This step is <strong>completely optional</strong>. Interests are visible to other members on your profile. Click an interest to select or deselect it — you can always change your interests later.
          </div>

          <% if @suggested.any? %>
            <p class="text-muted small mb-3">Click any interest to add it to your profile:</p>

            <div class="d-flex flex-wrap gap-2 mb-4">
              <% @suggested.each do |interest| %>
                <% selected = @user_interest_ids.include?(interest.id) %>
                <% if selected %>
                  <%= button_to profile_setup_remove_interest_path(interest),
                      method: :delete,
                      class: "btn btn-primary btn-sm rounded-pill",
                      form: { data: { turbo: false } } do %>
                    <i class="bi bi-check me-1"></i><%= interest.name %>
                    <i class="bi bi-x ms-1"></i>
                  <% end %>
                <% else %>
                  <%= button_to profile_setup_add_interest_path(interest),
                      method: :post,
                      class: "btn btn-outline-secondary btn-sm rounded-pill",
                      form: { data: { turbo: false } } do %>
                    <%= interest.name %>
                  <% end %>
                <% end %>
              <% end %>
            </div>

            <% interests_not_shown = @user_interests.reject { |i| @suggested.map(&:id).include?(i.id) } %>
            <% if interests_not_shown.any? %>
              <p class="text-muted small mb-2">Other interests you've selected:</p>
              <div class="d-flex flex-wrap gap-2 mb-4">
                <% interests_not_shown.each do |interest| %>
                  <%= button_to profile_setup_remove_interest_path(interest),
                      method: :delete,
                      class: "btn btn-primary btn-sm rounded-pill",
                      form: { data: { turbo: false } } do %>
                    <i class="bi bi-check me-1"></i><%= interest.name %>
                    <i class="bi bi-x ms-1"></i>
                  <% end %>
                <% end %>
              </div>
            <% end %>

          <% else %>
            <p class="text-muted fst-italic mb-4">No interests have been added yet. An admin can add interests under Settings.</p>
          <% end %>

          <!-- Add new interest -->
          <script type="application/json" id="all-interests-data"><%= @all_interests.to_json.html_safe %></script>
          <script type="application/json" id="user-interest-ids"><%= @user_interest_ids.to_a.to_json.html_safe %></script>

          <div class="border-top pt-4 mt-2">
            <p class="text-muted small mb-2">Don't see your interest? Add it:</p>
            <%= form_with url: profile_setup_suggest_interest_path, method: :post, local: true, class: "row g-2 align-items-end", id: "add-interest-form" do %>
              <div class="col-md-8 position-relative">
                <input type="text" name="interest_name" id="interest-name-input"
                       class="form-control form-control-sm"
                       placeholder="e.g., textile electronics, hydroponics…"
                       maxlength="80" autocomplete="off">
                <div id="interest-suggestions"
                     class="list-group shadow-sm position-absolute w-100 mt-1"
                     style="display:none; z-index:1000; max-height:220px; overflow-y:auto;"></div>
              </div>
              <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary btn-sm w-100">Add New Interest</button>
              </div>
            <% end %>
          </div>

          <script>
            (function () {
              var allInterests   = JSON.parse(document.getElementById('all-interests-data').textContent);
              var userInterestIds = new Set(JSON.parse(document.getElementById('user-interest-ids').textContent));
              var input       = document.getElementById('interest-name-input');
              var suggestions = document.getElementById('interest-suggestions');
              var form        = document.getElementById('add-interest-form');

              if (!input || !suggestions || !form) return;

              function showSuggestions(query) {
                suggestions.innerHTML = '';
                if (query.length === 0) { suggestions.style.display = 'none'; return; }

                var matches = allInterests.filter(function (i) {
                  return !userInterestIds.has(i.id) && i.name.toLowerCase().startsWith(query);
                }).slice(0, 10);

                if (matches.length === 0) { suggestions.style.display = 'none'; return; }

                matches.forEach(function (interest) {
                  var btn = document.createElement('button');
                  btn.type = 'button';
                  btn.className = 'list-group-item list-group-item-action py-1 small';
                  btn.textContent = interest.name;
                  btn.addEventListener('mousedown', function (e) {
                    // mousedown fires before blur; prevent blur from hiding list first
                    e.preventDefault();
                    input.value = interest.name;
                    suggestions.style.display = 'none';
                    form.submit();
                  });
                  suggestions.appendChild(btn);
                });

                suggestions.style.display = 'block';
              }

              input.addEventListener('input', function () {
                showSuggestions(this.value.toLowerCase().trim());
              });

              input.addEventListener('blur', function () {
                setTimeout(function () { suggestions.style.display = 'none'; }, 150);
              });

              input.addEventListener('focus', function () {
                if (this.value.trim().length > 0) {
                  showSuggestions(this.value.toLowerCase().trim());
                }
              });

              // Keyboard navigation
              input.addEventListener('keydown', function (e) {
                var items = suggestions.querySelectorAll('.list-group-item');
                if (!items.length) return;
                if (e.key === 'ArrowDown') {
                  e.preventDefault();
                  items[0].focus();
                } else if (e.key === 'Escape') {
                  suggestions.style.display = 'none';
                }
              });

              suggestions.addEventListener('keydown', function (e) {
                var items = Array.from(suggestions.querySelectorAll('.list-group-item'));
                var idx   = items.indexOf(document.activeElement);
                if (e.key === 'ArrowDown') {
                  e.preventDefault();
                  if (idx < items.length - 1) items[idx + 1].focus();
                } else if (e.key === 'ArrowUp') {
                  e.preventDefault();
                  if (idx > 0) items[idx - 1].focus(); else input.focus();
                } else if (e.key === 'Escape') {
                  suggestions.style.display = 'none';
                  input.focus();
                } else if (e.key === 'Enter') {
                  e.preventDefault();
                  items[idx].dispatchEvent(new MouseEvent('mousedown'));
                }
              });
            })();
          </script>

          <div class="d-flex justify-content-between mt-4">
            <%= link_to "Back", profile_setup_links_path, class: "btn btn-outline-secondary btn-lg" %>
            <div class="d-flex gap-2">
              <%= link_to "Skip", profile_setup_visibility_path, class: "btn btn-outline-secondary btn-lg" %>
              <%= link_to "Continue", profile_setup_visibility_path, class: "btn btn-primary btn-lg" %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
