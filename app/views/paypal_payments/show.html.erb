<div class="mb-4">
  <%= link_to "&larr; Back to PayPal payments".html_safe, paypal_payments_path, class: "text-decoration-none" %>
</div>

<div class="card shadow-sm border-0" data-controller="sensitive-reveal">
  <div class="card-body">
    <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-2 mb-3">
      <div>
        <h1 class="h4 mb-1">Transaction <%= @payment.paypal_id %></h1>
        <p class="mb-0 small text-secondary">Payer email and raw payment data are blurred until you show them.</p>
      </div>
      <button type="button" class="btn btn-sm btn-outline-secondary text-nowrap flex-shrink-0"
              data-action="click->sensitive-reveal#toggle">
        <span data-sensitive-reveal-target="label">Show contact details</span>
      </button>
    </div>

    <dl class="row mb-0">
      <dt class="col-sm-3 text-secondary">Status</dt>
      <dd class="col-sm-9"><span class="badge text-bg-secondary"><%= @payment.status.presence || "Unknown" %></span></dd>

      <dt class="col-sm-3 text-secondary">Amount</dt>
      <dd class="col-sm-9"><%= @payment.amount_with_currency || "—" %></dd>

      <dt class="col-sm-3 text-secondary">Transaction time</dt>
      <dd class="col-sm-9"><%= @payment.transaction_time ? l(@payment.transaction_time, format: :long) : "Unknown" %></dd>

      <dt class="col-sm-3 text-secondary">Type</dt>
      <dd class="col-sm-9"><%= @payment.transaction_type.presence || "—" %></dd>

      <dt class="col-sm-3 text-secondary">Payer</dt>
      <dd class="col-sm-9">
        <% if @payment.payer_name.present? %>
          <div><%= @payment.payer_name %></div>
        <% end %>
        <% if @payment.payer_email.present? %>
          <div data-sensitive-reveal-target="blurred"><%= mail_to @payment.payer_email %></div>
        <% end %>
        <% if @payment.payer_id.present? %>
          <div class="text-muted small">Payer ID: <%= @payment.payer_id %></div>
        <% end %>
        <% if @payment.payer_name.blank? && @payment.payer_email.blank? %>
          <span class="text-muted fst-italic">Not provided</span>
        <% end %>
      </dd>

      <dt class="col-sm-3 text-secondary">Member</dt>
      <dd class="col-sm-9">
        <% if @user_by_paypal_account_id.present? %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <%= link_to @user_by_paypal_account_id.display_name, user_path(@user_by_paypal_account_id), class: "text-decoration-none" %>
            <span class="text-muted small">(matched by PayPal account ID)</span>
            <%= button_to "Unlink", unlink_paypal_payment_path(@payment),
                method: :post, class: "btn btn-sm btn-outline-danger", data: { turbo: false,
                turbo_confirm: "Unlink this payment from #{@user_by_paypal_account_id.display_name}?" },
                title: "Remove the link between this payment and the member" %>
          </div>
        <% elsif @payment.dont_link? %>
          <span class="badge text-bg-secondary me-2">Don't Link</span>
          <%= button_to "Clear Don't Link", toggle_dont_link_paypal_payment_path(@payment),
              method: :post, class: "btn btn-sm btn-outline-secondary", data: { turbo: false } %>
        <% elsif @payment.payer_id.present? %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="text-muted fst-italic">No user found with matching PayPal account ID</span>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#linkUserModal">
              Link Member
            </button>
            <%= button_to "Create Member", create_member_paypal_payment_path(@payment),
                method: :post, class: "btn btn-sm btn-outline-success", data: { turbo: false },
                title: "Create a new member from this payment's information" %>
            <%= button_to "Don't Link", toggle_dont_link_paypal_payment_path(@payment),
                method: :post, class: "btn btn-sm btn-outline-secondary", data: { turbo: false },
                title: "Mark this payment as not needing to be linked" %>
          </div>
        <% else %>
          <span class="text-muted fst-italic">No payer ID available</span>
        <% end %>
      </dd>

      <dt class="col-sm-3 text-secondary">Last synced</dt>
      <dd class="col-sm-9"><%= @payment.last_synced_at ? l(@payment.last_synced_at, format: :long) : "Unknown" %></dd>

      <dt class="col-sm-3 text-secondary">Raw data</dt>
      <dd class="col-sm-9">
        <pre class="bg-body-secondary rounded p-3 mb-0" data-sensitive-reveal-target="blurred"><code class="text-body"><%= JSON.pretty_generate(@payment.raw_attributes) %></code></pre>
      </dd>
    </dl>
  </div>
</div>

<!-- Link User Modal -->
<% if @payment.payer_id.present? && @user_by_paypal_account_id.nil? %>
  <%= render 'shared/link_user_modal',
    modal_title: 'Link Member to Payment',
    form_url: link_user_paypal_payment_path(@payment),
    description: safe_join([
      'Select a user to link to this payment. The user\'s ',
      tag.code('paypal_account_id'),
      ' will be set to ',
      tag.code(h(@payment.payer_id.to_s)),
      '.'
    ]),
    users: @all_users %>
<% end %>

