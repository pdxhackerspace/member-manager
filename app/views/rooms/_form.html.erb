<%= form_with model: room, local: true do |f| %>
  <% if room.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(room.errors.count, 'error') %> prevented this room from being saved:</h6>
      <ul class="mb-0">
        <% room.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :position, class: "form-label" %>
    <%= f.number_field :position, class: "form-control", value: room.position || 0 %>
    <div class="form-text">Lower numbers appear first.</div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", rooms_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
