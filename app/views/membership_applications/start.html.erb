<div class="row justify-content-center py-5">
  <div class="col-12 col-md-10 col-lg-8">
    <%= render 'breadcrumbs', pages: @pages, current_page_number: 0 %>

    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body p-4 p-md-5">
        <% if @intro_content.present? %>
          <%= sanitize(@intro_content) %>
        <% else %>
          <h2 class="h4 mb-3">Membership Application</h2>
          <p>Your email has been verified. Click Continue to begin your application.</p>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <%= form_with url: apply_start_path, method: :post, local: true do |f| %>
          <input type="hidden" name="page_number" value="0">

          <% if @application %>
            <div class="alert alert-info mb-3">
              <i class="bi bi-info-circle me-1"></i>
              You have an application in progress. Click Continue to resume.
            </div>
          <% end %>

          <div class="d-flex justify-content-between">
            <%= link_to "← Back to Sign In", login_path, class: "btn btn-outline-secondary" %>
            <button type="submit" class="btn btn-primary btn-lg">Continue →</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
